# Copy this to .env and fill in your values
# cp .env.example .env

# Vision API (at least one required for scan feature)
ZAI_API_KEY=
ANTHROPIC_API_KEY=
VISION_PROVIDER=zai

# Change this to a random string for security
JWT_SECRET=pfms-local-secret-change-me

# Optional: change if you expose to network
CORS_ORIGIN=http://localhost
