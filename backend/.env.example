# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://pfms:pfms_password@localhost:5432/pfms

# Vision API Provider: "anthropic" or "zai"
VISION_PROVIDER=zai

# Anthropic API (optional, for vision/invoice scanning)
ANTHROPIC_API_KEY=

# Z.ai API (optional, GLM-5V-Turbo for vision/invoice scanning)
ZAI_API_KEY=

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# CORS
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d
